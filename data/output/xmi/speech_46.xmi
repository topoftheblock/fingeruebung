rkilinger/ged.ecore" xmlns:irr="http:///org/texttechnologylab/type/morphosyn/tag/irr.ecore" xmlns:convpurp3="http:///org/texttechnologylab/type/morphosyn/tag/conv/convpurp3.ecore" xmlns:type12="http:///org/texttechnologylab/uima/type.ecore" xmlns:convconccond="http:///org/texttechnologylab/type/morphosyn/tag/conv/convconccond.ecore" xmlns:tag="http:///org/texttechnologylab/type/morphosyn/tag.ecore" xmlns:cnjcoora1="http:///org/texttechnologylab/type/morphosyn/tag/cnj/cnjcoora1.ecore" xmlns:activelearner="http:///org/texttechnologylab/annotation/administration/activelearner.ecore" xmlns:cond3="http:///org/texttechnologylab/type/morphosyn/tag/cond3.ecore" xmlns:cnjcoorc="http:///org/texttechnologylab/type/morphosyn/tag/cnj/cnjcoorc.ecore" xmlns:necess1="http:///org/texttechnologylab/type/morphosyn/tag/necess1.ecore" xmlns:cnjpurp="http:///org/texttechnologylab/type/morphosyn/tag/cnj/cnjpurp.ecore" xmlns:convconc="http:///org/texttechnologylab/type/morphosyn/tag/conv/convconc.ecore" xmlns:iaa="http:///org/texttechnologylab/iaa.ecore" xmlns:pp6="http:///org/texttechnologylab/type/morphosyn/tag/pp6.ecore" xmlns:convcoord="http:///org/texttechnologylab/type/morphosyn/tag/conv/convcoord.ecore" xmlns:noNamespace="http:///uima/noNamespace.ecore" xmlns:isobase="http:///org/texttechnologylab/annotation/semaf/isobase.ecore" xmlns:ocr="http:///org/texttechnologylab/annotation/ocr.ecore" xmlns:cnj="http:///org/texttechnologylab/type/morphosyn/tag/cnj.ecore" xmlns:decl="http:///org/texttechnologylab/type/morphosyn/tag/decl.ecore" xmlns:isotimeml="http:///org/texttechnologylab/annotation/semaf/isotimeml.ecore" xmlns:cnjcoora2="http:///org/texttechnologylab/type/morphosyn/tag/cnj/cnjcoora2.ecore" xmlns:convcond1="http:///org/texttechnologylab/type/morphosyn/tag/conv/convcond1.ecore" xmlns:convpurp1="http:///org/texttechnologylab/type/morphosyn/tag/conv/convpurp1.ecore" xmlns:duui="http:///org/texttechnologylab/duui.ecore" xmlns:dependency="http:///de/tudarmstadt/ukp/dkpro/core/api/s