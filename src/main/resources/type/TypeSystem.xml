<?xml version="1.0" encoding="UTF-8"?>
<typeSystemDescription xmlns="http://uima.apache.org/resourceSpecifier">
    <name>ParliamentTypeSystem</name>
    <description>Ein UIMA TypeSystem zur Erfassung von Rednern, Redeinhalt und Sitzungsinformationen.</description>
    <version>1.0</version>
    <vendor>TextTechnologyLab</vendor>
    <types>
        <!-- Typ: Sitzungsinformationen -->
        <typeDescription>
            <name>org.texttechnologylab.practical.sose26.christian.type.Sitzungsinformationen</name>
            <description>Enthält Metadaten zur aktuellen Sitzung (z.B. Plenarsitzung).</description>
            <supertypeName>uima.tcas.Annotation</supertypeName>
            <features>
                <featureDescription>
                    <name>wahlperiode</name>
                    <description>Die Nummer der Wahlperiode.</description>
                    <rangeTypeName>uima.cas.Integer</rangeTypeName>
                </featureDescription>
                <featureDescription>
                    <name>sitzungsNummer</name>
                    <description>Die laufende Nummer der Sitzung.</description>
                    <rangeTypeName>uima.cas.Integer</rangeTypeName>
                </featureDescription>
                <featureDescription>
                    <name>datum</name>
                    <description>Das Datum der Sitzung.</description>
                    <rangeTypeName>uima.cas.String</rangeTypeName>
                </featureDescription>
            </features>
        </typeDescription>

        <!-- Typ: Redner -->
        <typeDescription>
            <name>org.texttechnologylab.practical.sose26.christian.type.Redner</name>
            <description>Informationen zur sprechenden Person.</description>
            <supertypeName>uima.tcas.Annotation</supertypeName>
            <features>
                <featureDescription>
                    <name>vorname</name>
                    <description>Der Vorname des Redners.</description>
                    <rangeTypeName>uima.cas.String</rangeTypeName>
                </featureDescription>
                <featureDescription>
                    <name>nachname</name>
                    <description>Der Nachname des Redners.</description>
                    <rangeTypeName>uima.cas.String</rangeTypeName>
                </featureDescription>
                <featureDescription>
                    <name>partei</name>
                    <description>Die Fraktion oder Partei des Redners.</description>
                    <rangeTypeName>uima.cas.String</rangeTypeName>
                </featureDescription>
                <featureDescription>
                    <name>funktion</name>
                    <description>Die Rolle des Redners.</description>
                    <rangeTypeName>uima.cas.String</rangeTypeName>
                </featureDescription>
            </features>
        </typeDescription>

        <!-- Typ: Redeinhalt -->
        <typeDescription>
            <name>org.texttechnologylab.practical.sose26.christian.type.Redeinhalt</name>
            <description>Markiert den eigentlichen Redeinhalt.</description>
            <supertypeName>uima.tcas.Annotation</supertypeName>
            <features>
                <featureDescription>
                    <name>redner</name>
                    <description>Referenz auf die Person, die diese Rede hält.</description>
                    <rangeTypeName>org.texttechnologylab.practical.sose26.christian.type.Redner</rangeTypeName>
                </featureDescription>
                <featureDescription>
                    <name>tagesordnungspunkt</name>
                    <description>Der zugehörige Tagesordnungspunkt (TOP).</description>
                    <rangeTypeName>uima.cas.String</rangeTypeName>
                </featureDescription>
                <featureDescription>
                    <name>redeTyp</name>
                    <description>Reguläre Rede, Zwischenruf, etc.</description>
                    <rangeTypeName>uima.cas.String</rangeTypeName>
                </featureDescription>
            </features>
        </typeDescription>
    </types>
</typeSystemDescription>